{
  "name": "mindwp-web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.1.0",
  "scripts": {
    "dev": "next dev",
    "dev-ref": "pnpm --dir _dev-reference/current-site exec next dev -p 3010",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "check:names": "node scripts/check-names.mjs",
    "check:contrast": "node scripts/check-contrast.mjs",
    "check": "pnpm typecheck && pnpm lint && pnpm check:names && pnpm check:contrast",
    "test": "playwright test",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "opennextjs-cloudflare build && wrangler dev",
    "cf:deploy": "opennextjs-cloudflare build && wrangler deploy"
  },
  "dependencies": {
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "gsap": "^3.15.0",
    "lucide-react": "0.576.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "resend": "6.12.3",
    "tailwind-merge": "3.6.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@playwright/test": "1.60.0",
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "20.19.41",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.59.3",
    "@typescript-eslint/parser": "8.59.3",
    "axe-core": "4.11.4",
    "eslint": "9.39.4",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "playwright": "1.60.0",
    "postcss": "8.4.31",
    "prettier": "3.8.3",
    "tailwindcss": "4.3.0",
    "typescript": "5.9.3"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "sharp"
    ]
  }
}
