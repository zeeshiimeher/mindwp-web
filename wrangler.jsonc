{
  // Cloudflare Workers config for the OpenNext build. Deploy is free-tier.
  // Run `pnpm cf:deploy` (after `pnpm add -D @opennextjs/cloudflare wrangler`).
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mindwp-web",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-03-25",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  }
}
