# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/output/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# local renderable reference snapshots
/_dev-reference/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (keep the example tracked)
.env*
!.env.example
.dev.vars

# cloudflare / opennext
/.open-next/
/.wrangler/

# testing
/test-results/
/playwright-report/
/blob-report/
/.lighthouseci/

# typescript
*.tsbuildinfo
next-env.d.ts
